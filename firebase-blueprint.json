{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth unique ID" },
        "displayName": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "photoURL": { "type": "string", "format": "uri" },
        "role": { "type": "string", "enum": ["client", "agent"], "description": "User role: client or real estate agent" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "email", "role"]
    },
    "Property": {
      "title": "Property",
      "description": "Real estate property listing",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number", "description": "Price per month for rentals or total price for sales" },
        "type": { "type": "string", "enum": ["rental", "sale"] },
        "address": { "type": "string" },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" }
          }
        },
        "images": {
          "type": "array",
          "items": { "type": "string", "format": "uri" }
        },
        "agentId": { "type": "string", "description": "UID of the agent who uploaded the property" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "price", "type", "address", "agentId", "createdAt"]
    }
  },
  "firestore": {
    "users": {
      "schema": "User",
      "description": "Public and private user profiles"
    },
    "properties": {
      "schema": "Property",
      "description": "All available property listings"
    }
  }
}
