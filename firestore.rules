rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // --- Collection: Users ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'displayName', 'email', 'role', 'createdAt']) &&
               data.keys().size() == 5 &&
               data.uid == request.auth.uid &&
               data.displayName is string && data.displayName.size() <= 100 &&
               data.email is string && data.email.size() <= 100 &&
               data.role in ['client', 'agent'] &&
               data.createdAt is int;
      }

      allow get: if isSignedIn();
      allow list: if false; // Users shouldn't be listable normally for privacy
      
      allow create: if isSignedIn() && isValidUser(request.resource.data) && userId == request.auth.uid;
      
      allow update: if isOwner(userId) && isValidUser(request.resource.data) && (
        // Protect role - maybe allow switching for demo, but usually protected
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['role', 'displayName', 'photoURL'])
      );
    }

    // --- Collection: Properties ---
    match /properties/{propertyId} {
      function isValidProperty(data) {
        return data.keys().hasAll(['title', 'description', 'price', 'type', 'address', 'location', 'images', 'agentId', 'createdAt', 'updatedAt']) &&
               // Required fields types
               data.title is string && data.title.size() <= 200 &&
               data.price is number && data.price >= 0 &&
               data.type == 'rental' &&
               data.agentId == request.auth.uid;
      }

      function isAgent() {
        return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'agent';
      }

      allow read: if true; // Properties are public for searching
      
      allow create: if isAgent() && isValidProperty(request.resource.data);
      
      allow update: if isAgent() && resource.data.agentId == request.auth.uid && 
                       isValidProperty(request.resource.data) &&
                       request.resource.data.createdAt == resource.data.createdAt;
                       
      allow delete: if isAgent() && resource.data.agentId == request.auth.uid;
    }
  }
}
